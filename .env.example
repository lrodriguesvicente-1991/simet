# =====================================================================
# SIMET V2 - Variaveis de ambiente (template)
# Copie para .env e preencha com valores reais. NAO comite o .env.
# =====================================================================

# -------- Banco de dados (Supabase) --------
DB_HOST=aws-0-sa-east-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.xxxxxxxxxxxx
DB_PASS=troque-esta-senha

# -------- Autenticacao da API --------
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria
API_USER=admin
API_PASS=troque-esta-senha

# -------- CORS --------
# Lista separada por virgula. Em producao coloque o dominio real.
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,https://seu-dominio.com.br

# -------- LLM (Ollama) — usado apenas no modo IA --------
OLLAMA_URL=http://host.docker.internal:11434/v1
OLLAMA_MODEL=simet-extrator

# -------- Scraping (runtime) --------
SIMET_HEADLESS=1
SIMET_NAVEGACAO=RAPIDA
SIMET_DELAY_EXTRA_S=0

# -------- Modo de extracao --------
# auto: detecta GPU NVIDIA >= 8GB e usa IA; senao usa deterministico (dataLayer + regex + dicionario).
# ia: forca IA (exige GPU para nao travar).
# deterministico: forca sem IA (rapido em qualquer maquina).
SIMET_MODO=auto
